@page "/"

@using PracticoBiblioteca.Shared.DTOs
@using PracticoBiblioteca.Services.Interfaces
@inject NavigationManager navigation
@inject IUsuarioService usuarioService
@inject ISesionService SesionService


<div class="d-flex justify-content-center align-items-center min-vh-100 bg-light">
    <div class="card shadow-lg border-0 rounded-4" style="max-width: 420px; width: 100%;">
        <div class="card-body p-5">
            <div class="text-center mb-4">
                <i class="bi bi-book-half text-primary display-4"></i>
                <h3 class="mt-2 fw-bold text-primary">Biblioteca Virtual</h3>
                <p class="text-muted mb-0">Accedé a tu cuenta</p>
            </div>

            @if (isLoading)
            {
                <div class="text-center mb-3">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                    <span class="ms-2 text-primary fw-semibold">Verificando datos...</span>
                </div>
            }

            <EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="form-floating mb-3">
                    <InputText id="email" class="form-control rounded-3" @bind-Value="loginModel.Email" placeholder="Correo electrónico" />
                    <label for="email"><i class="bi bi-envelope-at-fill me-2 text-primary"></i>Correo electrónico</label>
                    <ValidationMessage For="@(() => loginModel.Email)" />
                </div>

                <div class="form-floating mb-4">
                    <InputText id="password" type="password" class="form-control rounded-3" @bind-Value="loginModel.Password" placeholder="Contraseña" />
                    <label for="password"><i class="bi bi-shield-lock-fill me-2 text-primary"></i>Contraseña</label>
                    <ValidationMessage For="@(() => loginModel.Password)" />
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold shadow-sm">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Ingresar
                </button>

                <div class="text-center mt-3">
                    <a href="#" class="text-decoration-none small text-secondary">
                        <i class="bi bi-question-circle me-1"></i>¿Olvidaste tu contraseña?
                    </a>
                </div>
            </EditForm>
        </div>
    </div>
</div>


@code {
    private LoginModel loginModel = new();
    private bool isLoading = false;

    private async Task HandleLogin()
    {
        var login = new LoginDTO
        {
            Email = loginModel.Email,
            Password = loginModel.Password
        };

        isLoading = true;
        var result = await usuarioService.AuthenticateAsync(login);
        isLoading = false;

        if (result != null)
        {
            SesionService.GuardarSesion(result); 
            navigation.NavigateTo("/menu");
        }
        else
        {
            Console.WriteLine("Login incorrecto o usuario inactivo");
        }
    }
}
