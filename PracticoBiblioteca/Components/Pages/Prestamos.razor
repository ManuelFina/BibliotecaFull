@page "/prestamos"
@inject IPrestamoService PrestamoService
@inject ISesionService SesionService
@inject NavigationManager Navigation

<h3 class="text-center mt-3 text-primary fw-bold">
    <i class="bi bi-box2-heart-fill me-2"></i> Gestión de Préstamos
</h3>

@if (isLoading)
{
    <div class="text-center mt-4">
        <div class="spinner-border text-primary" role="status"></div>
        <p class="mt-2">Cargando préstamos...</p>
    </div>
}
else if (prestamos.Count == 0)
{
    <div class="alert alert-info mt-4 text-center">
        No hay préstamos registrados.
    </div>
}
else
{
    <table class="table table-hover mt-3 align-middle shadow-sm rounded">
        <thead class="table-primary">
            <tr>
                <th>ID</th>
                <th>Libro</th>
                <th>Usuario</th>
                <th>Fecha Préstamo</th>
                <th>Fecha Devolución</th>
                <th>Estado</th>
                @if (esAdmin)
                {
                    <th>Acciones</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var p in prestamos)
            {
                <tr>
                    <td>@p.Id</td>
                    <td>@p.Libro?.Titulo</td>
                    <td>@p.Usuario?.Nombre</td>
                    <td>@p.FechaPrestamo.ToShortDateString()</td>
                    <td>@(p.FechaDevolucion.ToShortDateString() ?? "-")</td>
                    <td>
                        @if (p.Devuelto)
                        {
                            <span class="badge bg-success">Devuelto</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Pendiente</span>
                        }
                    </td>
                    @if (esAdmin)
                    {
                        <td>
                            @if (!p.Devuelto)
                            {
                                <button class="btn btn-sm btn-success me-2" @onclick="() => Devolver(p.Id)">
                                    <i class="bi bi-arrow-return-left"></i> Devolver
                                </button>
                            }
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
}

@if (!esAdmin)
{
    <div class="card mt-4 p-3 shadow-sm">
        <h5 class="text-primary">Solicitar nuevo préstamo</h5>
        <div class="input-group mt-3">
            <input type="number" class="form-control" placeholder="ID del libro" @bind="nuevoPrestamo.LibroId" />
            <button class="btn btn-primary" @onclick="CrearPrestamo">
                <i class="bi bi-plus-circle"></i> Solicitar
            </button>
        </div>
    </div>
}

<style>
    .table {
        border-radius: 12px;
        overflow: hidden;
    }

    .card {
        max-width: 500px;
        margin: auto;
    }
</style>

@code {
    private List<Prestamo> prestamos = new();
    private PrestamoDTO nuevoPrestamo = new();
    private bool esAdmin = false;
    private bool isLoading = true;
    private int usuarioId;

    protected override async Task OnInitializedAsync()
    {
        var sesion = await SesionService.ObtenerSesionAsync();

        if (sesion is null)
        {
            Navigation.NavigateTo("/");
            return;
        }

        esAdmin = string.Equals(sesion.Rol, "Admin", StringComparison.OrdinalIgnoreCase);
        usuarioId = sesion.UsuarioId;

        await CargarPrestamos();
    }

    private async Task CargarPrestamos()
    {
        isLoading = true;
        prestamos = esAdmin
            ? await PrestamoService.ObtenerTodosAsync()
            : await PrestamoService.ObtenerPorUsuarioAsync(usuarioId);

        isLoading = false;
    }

    private async Task CrearPrestamo()
    {
        if (nuevoPrestamo.LibroId <= 0) return;

        nuevoPrestamo.UsuarioId = usuarioId;
        await PrestamoService.CrearAsync(nuevoPrestamo);
        nuevoPrestamo = new PrestamoDTO();
        await CargarPrestamos();
    }

    private async Task Devolver(int id)
    {
        await PrestamoService.DevolverAsync(id);
        await CargarPrestamos();
    }
}
